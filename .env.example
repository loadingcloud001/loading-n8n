# n8n Environment Variables
# Copy this file to .env and fill in the values

# DO Managed PostgreSQL
DO_DB_HOST=cmp-postgres-do-user-xxxxx-0.db.ondigitalocean.com
DO_DB_PORT=25060
DO_DB_NAME=loading_postgres
DO_DB_USER=doadmin
DO_DB_PASSWORD=<from DO Database Console>

# Auth0 SSO
AUTH0_CLIENT_SECRET=<from auth0.age>
