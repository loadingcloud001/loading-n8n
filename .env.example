# n8n Version (pin to specific version for production, use 'latest' for dev)
# Check available versions: https://hub.docker.com/r/n8nio/n8n/tags
N8N_VERSION=latest

# Service
N8N_HOST=n8n.loadingtechnology.app
N8N_PORT=5678
WEBHOOK_URL=https://n8n.loadingtechnology.app
N8N_PROTOCOL=https
N8N_AUTH_MODE=oauth2

# Auth0 SSO
N8N_OAUTH2_CLIENT_ID=ws8wBaPdXYFWwNAtva4YWQmCuT1Ah0AT
AUTH0_CLIENT_SECRET=<from auth0.age>
N8N_OAUTH2_ISSUER=https://dev-63h751qzectzner7.us.auth0.com/

# DO Managed PostgreSQL — loading-postgres cluster (DO 003)
# Host: private-loading-postgres-do-user-34964671-0.i.db.ondigitalocean.com
# Port: 25060  |  User: doadmin  |  SSL: require
# Databases: defaultdb, loading_grafana, loading_n8n ← n8n uses this, speckle_fresh
DO_DB_HOST=private-loading-postgres-do-user-34964671-0.i.db.ondigitalocean.com
DO_DB_PORT=25060
DO_DB_NAME=loading_n8n
DO_DB_USER=doadmin
